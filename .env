# ===========================================
# BACKEND ENVIRONMENT CONFIGURATION
# ===========================================

# Server Port
PORT=5000

# Frontend URL (update for deployment)
# For local: http://localhost:5173
# For Vercel: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173

# MongoDB Connection
# Replace with your MongoDB Atlas connection string for production
MONGODB_URI=mongodb://localhost:27017/dataclinic

# JWT Secret (change in production!)
JWT_SECRET=supersecret

# Session Secret (change in production!)
SESSION_SECRET=keyboardcat

# Google OAuth (required for Google Login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_secret
# For local: http://localhost:5000/auth/google/callback
# For Render: https://your-backend.onrender.com/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Email (for password reset)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
