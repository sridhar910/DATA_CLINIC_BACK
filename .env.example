# ===========================================
# BACKEND ENVIRONMENT CONFIGURATION
# ===========================================

# Copy this file to .env and fill in your values

# Server Port
PORT=5000

# Frontend URL
# LOCAL: http://localhost:5173
# PRODUCTION: https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/dataclinic

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Session Secret
SESSION_SECRET=your_session_secret_here

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
# Callback URL (must match Google Console settings)
# LOCAL: http://localhost:5000/auth/google/callback
# PRODUCTION: https://data-clinic-back-2.onrender.com/auth/google/callback
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Email
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
